<Window x:Class="AionPingLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ping" Height="70" Width="50"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="True" Opacity="1.0"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseMove="Window_MouseMove">
    <Grid Background="#01000000" Cursor="Hand">
        <!-- Background captures hit-testing -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Path x:Name="WifiIcon" Stretch="Uniform" Fill="Gray" Margin="2" Width="30" Height="30"
                  Data="M12 3C7.95 3 4.21 4.34 1.2 6.6L3 9C5.5 7.12 8.62 6 12 6C15.38 6 18.5 7.12 21 9L22.8 6.6C19.79 4.34 16.05 3 12 3M12 9C9.3 9 6.81 9.89 4.8 11.4L6.6 13.8C8.1 12.67 9.97 12 12 12C14.03 12 15.9 12.67 17.4 13.8L19.2 11.4C17.19 9.89 14.7 9 12 9M12 15C10.65 15 9.4 15.45 8.4 16.2L12 21L15.6 16.2C14.6 15.45 13.35 15 12 15Z"/>
            <TextBlock x:Name="PingText" Text="--- ms" FontFamily="Consolas, Arial" FontSize="11" FontWeight="Bold" Margin="0,2,0,0" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
